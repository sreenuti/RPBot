# LLM provider: openai, gemini, or local
LLM_PROVIDER=openai

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini
# Optional: route OpenAI SDK to a compatible proxy (Together, Groq, etc.)
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MAX_TOKENS=512

# Local / self-hosted or Hugging Face Inference Endpoint (OpenAI-compatible /v1)
# LLM_PROVIDER=local
# LOCAL_BASE_URL=http://127.0.0.1:8000/v1
# LOCAL_BASE_URL=https://YOUR_ENDPOINT.us-east-1.aws.endpoints.huggingface.cloud/v1
# LOCAL_MODEL=sreenuti/realpage-message-agent-v1   # full Hub repo id on HF Endpoints
# LOCAL_API_KEY=local
# LOCAL_API_KEY=hf_...   # HF token when using Inference Endpoints
# LOCAL_JSON_MODE=true
# LOCAL_MAX_TOKENS=384
# LLM_WARMUP=true
# PROMPT_STYLE=full        # default; compact or training for experiments

# Hugging Face Hub upload (scripts/upload_model_hub.py)
# HF_TOKEN=hf_...

# Google Gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash
